generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  mangas    Manga[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MangaStatus {
  READ
  READING
  WANT_TO_READ
}

model Manga {
  id            String      @id @default(cuid())
  name          String
  volume        Int
  totalVolumes  Int?        
  ownedVolumes  Int[]       @default([])
  status        MangaStatus @default(WANT_TO_READ)
  note          Float?      @map("rating")
  genre         String?
  coverUrl      String?
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([userId, name, volume])
}